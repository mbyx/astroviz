{
    "name": "astroviz-dev",
    "image": "astroviz:latest",
    "initializeCommand": "xhost +local:docker",
    "runArgs": [
        "--name",
        "astroviz-vscode",
        "--net=host",
        "--ipc=host",
        "--privileged",
        "-v",
        "/tmp/.X11-unix:/tmp/.X11-unix",
        "-v",
        "/dev:/dev",
        "-e",
        "QT_X11_NO_MITSHM=1"
    ],
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "QT_X11_NO_MITSHM": "1"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    },
    "postCreateCommand": "colcon build --symlink-install && echo 'source /workspaces/astroviz/install/setup.bash' >> ~/.bashrc"
}